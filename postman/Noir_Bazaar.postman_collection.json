  "item": [
    {
      "name": "01. Connection Check",
      "item": [
        {
          "name": "Get Welcome Message",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": [""]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "02. Customer Authentication",
      "item": [
        {
          "name": "Send Customer OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"signing_customer@example.com\",\n  \"role\": \"ROLE_CUSTOMER\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/sent/login-signup-otp",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["auth", "sent", "login-signup-otp"]
            }
          },
          "response": []
        },
        {
          "name": "Customer Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"otp\": \"123456\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/signup",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["auth", "signup"]
            }
          },
          "response": []
        },
        {
          "name": "Customer Login (Signing)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.jwtToken) {",
                  "    pm.globals.set(\"customer_jwt\", jsonData.jwtToken);",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/signing",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["auth", "signing"]
            }
          },
          "response": []
        },
        {
          "name": "Get Customer Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customer_jwt}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/users/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["users", "profile"]
            }
          },
          "response": []
        }
      ]
